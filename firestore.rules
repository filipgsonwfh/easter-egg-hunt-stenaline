rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Egg tokens - only accessible by exact document ID (no listing)
    match /eggs/{eggId} {
      allow get: if true;
      allow list: if false;
      allow write: if true;
    }

    // Public progress - anyone can read which pieces are found
    match /progress/{pieceId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
