rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /eggs/{eggId} {
      // Anyone can read egg status (view progress)
      allow read: if true;
      // Anyone can create/update an egg (scanning QR code)
      // The transaction in app.js prevents double-scanning
      allow write: if true;
    }
  }
}
